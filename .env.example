# ── Auth ──────────────────────────────────────────
# Contraseña para entrar al dashboard (pon algo fuerte)
DASHBOARD_PASSWORD=pon_aqui_tu_clave_secreta

# Secreto para firmar el JWT (mínimo 32 caracteres aleatorios)
# Genera uno en: https://1password.com/password-generator/
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga_32chars

# ── Bitcoin ───────────────────────────────────────
# Dirección principal (se usa para ckpool por defecto)
BTC_ADDRESS=bc1qctwh3kzh74uedva9awm8zpq9jfpqd7p6vkdlfe

# Si tu dirección en public-pool es DIFERENTE a BTC_ADDRESS, ponla aquí.
# Si es la misma, déjala vacía.
PUBLIC_POOL_ADDRESS=

# ── Mineros (AxeOS) ───────────────────────────────
MINER_1_NAME=Bitaxe
MINER_1_URL=http://192.168.11.48

