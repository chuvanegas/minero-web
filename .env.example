# ── Auth ──────────────────────────────────────────
# Contraseña para entrar al dashboard (pon algo fuerte)
DASHBOARD_PASSWORD=pon_aqui_tu_clave_secreta

# Secreto para firmar el JWT (mínimo 32 caracteres aleatorios)
# Genera uno en: https://1password.com/password-generator/
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga_32chars

# ── Bitcoin ───────────────────────────────────────
BTC_ADDRESS=bc1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Mineros (AxeOS) ───────────────────────────────
MINER_1_NAME=Bitaxe
MINER_1_URL=http://192.168.10.244

# Agrega más si tienes:
# MINER_2_NAME=NerdQaxe Oficina
